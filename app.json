{
  "expo": {
    "name": "VysyamalaApp",
    "slug": "vysyamala",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/fixed-icon-vysyamala.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vysmala.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to save PDF reports.",
        "NSDocumentDirectoryUsageDescription": "This app needs access to save PDF reports."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/fixed-icon-vysyamala.png",
        "backgroundColor": "#ffffff"
      },
      "usesCleartextTraffic": true,
      "package": "com.vysmala.app",
      "versionCode": 52,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.DOWNLOAD_WITHOUT_NOTIFICATION",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ec179e54-62e0-4044-ae3b-11e485cc4d43"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/524bae3e-64b1-46a5-bbbc-6a0d84357d8e"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "ndkVersion": "27.2.12479018",
            "packagingOptions": {
              "jniLibs": {
                "useLegacyPackaging": false
              }
            },
            "extraProguardRules": "-keep class * { *; }"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to save the matching report.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save the matching report to your photos.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": [
            "photo",
            "video"
          ]
        }
      ]
    ],
    "owner": "dhivya_p98"
  }
}