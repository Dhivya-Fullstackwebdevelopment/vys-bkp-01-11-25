{
  "expo": {
    "name": "VysyamalaApp",
    "slug": "vysyamala",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/fixed-icon-vysyamala.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vysmala.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/fixed-icon-vysyamala.png",
        "backgroundColor": "#ffffff"
      },
      "usesCleartextTraffic": true,
      "package": "com.vysmala.app",
      "versionCode": 51
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ec179e54-62e0-4044-ae3b-11e485cc4d43"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/524bae3e-64b1-46a5-bbbc-6a0d84357d8e"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "ndkVersion": "27.2.12479018",
            "packagingOptions": {
              "jniLibs": {
                "useLegacyPackaging": false
              }
            },
            "extraProguardRules": "-keep class * { *; }"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "owner": "dhivya_p98"
  }
}